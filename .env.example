# Copy to .env and fill in. Never commit .env.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=orders_reader
MYSQL_PASSWORD=
MYSQL_DATABASE=your_shop_db
# Comma-separated column names to SELECT (must be safe identifiers)
MYSQL_ORDERS_TABLE=orders
MYSQL_ORDERS_COLUMNS=id,created_at,status,total,customer_email
